// getSqrtPriceAtTickSweep() -> 198041777680115139878319777
// getTickAtSqrtPriceSweep() -> -70638
// getSqrtPriceAtTick(int24): -887272 -> 4295128739
// getSqrtPriceAtTick(int24): 887272 -> 1461446703485210103287273052203988822378723970342
// getTickAtSqrtPrice(uint160): 4295128739 -> -887272
// getTickAtSqrtPrice(uint160): 1461446703485210103287273052203988822378723970341 -> 887271
